                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "message": {
                                            "type": "string",
                                            "example": "No query results for model [Fleet]."
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    }
                }
